<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>BOLSONARO • Início</title>
<style>
:root {
  --bg: #0f1218;
  --surface: #171b23;
  --surface-light: #1e232e;
  --line: #262c36;
  --line-light: #303847;
  --text: #e9edf4;
  --text-light: #ffffff;
  --muted: #9aa3b2;
  --muted-light: #b8c2d1;
  --accent: #4d7cff;
  --accent-light: #6b94ff;
  --success: #4ade80;
  --error: #f87171;
  --warning: #fbbf24;
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html, body {
  height: 100%;
  scroll-behavior: smooth;
}

body {
  margin: 0;
  font-family: 'Inter', system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
  color: var(--text);
  background: radial-gradient(ellipse at top, #0e1117 0%, #0f1218 70%);
  line-height: 1.5;
}

/* Tipografia melhorada */
h1, h2, h3, h4 {
  font-weight: 600;
  line-height: 1.2;
  color: var(--text-light);
}

/* Header estilizado */
.header {
  padding: 40px 20px 24px;
  text-align: center;
  position: relative;
}

.logo {
  margin: 0 0 12px;
  font-weight: 900;
  letter-spacing: .15em;
  line-height: 1;
  font-size: clamp(36px, 7vw, 64px);
  background: linear-gradient(90deg, #bcd4ff, #8fb2ff, #bcd4ff);
  background-size: 200% 100%;
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  animation: logo 14s linear infinite;
  text-shadow: 0 2px 8px rgba(143, 178, 255, 0.15);
}

@keyframes logo {
  0% { background-position: 0 50%; }
  100% { background-position: 100% 50%; }
}

.topbar {
  display: flex;
  justify-content: center;
  gap: 12px;
  color: var(--muted-light);
  font-size: 0.95rem;
  flex-wrap: wrap;
  margin-top: 8px;
}

.pill {
  padding: 6px 14px;
  border: 1px solid var(--line-light);
  border-radius: 999px;
  background: rgba(20, 24, 33, 0.6);
  color: var(--muted-light);
  backdrop-filter: blur(4px);
  font-weight: 500;
  transition: all 0.2s ease;
}

.pill:hover {
  background: rgba(30, 35, 46, 0.8);
  border-color: var(--accent);
  color: var(--text-light);
}

/* Grid de cards modernizado */
.grid {
  max-width: 1200px;
  margin: 32px auto 40px;
  display: grid;
  gap: 20px;
  padding: 0 20px;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  animation: fadeIn 0.4s ease-out forwards;
}

.card {
  display: block;
  text-decoration: none;
  color: inherit;
  background: var(--surface);
  border: 1px solid var(--line);
  border-radius: 18px;
  padding: 24px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
  transition: all 0.25s cubic-bezier(0.2, 0, 0, 1);
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, rgba(77, 124, 255, 0.1) 0%, rgba(77, 124, 255, 0) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.card:hover {
  border-color: var(--accent);
  transform: translateY(-5px);
  box-shadow: 0 16px 40px rgba(0, 0, 0, 0.45);
}

.card:hover::before {
  opacity: 1;
}

.card h3 {
  margin: 0 0 10px;
  font-size: 1.2rem;
  position: relative;
  z-index: 1;
}

.card p {
  margin: 0;
  color: var(--muted);
  font-size: 0.95rem;
  position: relative;
  z-index: 1;
}

.card-icon {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
  background: rgba(77, 124, 255, 0.1);
  color: var(--accent);
  font-size: 1.5rem;
}

/* Footer atualizado */
.footer {
  max-width: 1100px;
  margin: 30px auto 50px;
  color: var(--muted);
  text-align: center;
  font-size: 0.85rem;
  padding: 0 20px;
}

/* Botão de logout moderno */
.btn-logout {
  position: fixed;
  right: 20px;
  top: 20px;
  background: rgba(26, 31, 42, 0.8);
  border: 1px solid var(--line-light);
  color: var(--text);
  padding: 10px 16px;
  border-radius: 12px;
  text-decoration: none;
  font-size: 0.9rem;
  display: flex;
  align-items: center;
  gap: 8px;
  backdrop-filter: blur(4px);
  transition: all 0.2s ease;
  z-index: 50;
}

.btn-logout:hover {
  background: rgba(40, 47, 62, 0.9);
  border-color: var(--accent);
  transform: translateY(-1px);
}

/* Modal modernizado */
.modal {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(10, 12, 18, 0.85);
  z-index: 100;
  backdrop-filter: blur(6px);
}

.hidden {
  display: none;
}

.modal-card {
  width: min(540px, 92vw);
  background: var(--surface);
  border: 1px solid var(--line-light);
  border-radius: 20px;
  padding: 24px 24px 20px;
  box-shadow: 0 24px 80px rgba(0, 0, 0, 0.7);
  transform: translateY(10px);
  opacity: 0;
  animation: pop 0.25s cubic-bezier(0.2, 0, 0, 1) forwards;
}

@keyframes pop {
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-card h3 {
  margin: 0 0 16px;
  font-size: 1.3rem;
  color: var(--text-light);
}

.f {
  margin: 16px 0;
}

.f label {
  display: block;
  margin: 0 0 8px;
  color: var(--muted-light);
  font-size: 0.94rem;
  font-weight: 500;
}

.f input,
.f select,
.f textarea {
  width: 100%;
  padding: 14px;
  border: 1px solid var(--line);
  border-radius: 14px;
  background: var(--surface-light);
  color: var(--text);
  outline: none;
  font-family: inherit;
  font-size: 0.95rem;
  transition: all 0.2s ease;
}

.f input:focus,
.f select:focus,
.f textarea:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 4px rgba(77, 124, 255, 0.2);
  background: var(--surface-light);
}

.row {
  display: flex;
  gap: 12px;
  justify-content: flex-end;
  margin-top: 20px;
}

.btn {
  border: 1px solid var(--line-light);
  border-radius: 14px;
  background: var(--surface-light);
  color: var(--text);
  padding: 12px 18px;
  cursor: pointer;
  font-weight: 500;
  font-size: 0.95rem;
  transition: all 0.2s ease;
}

.btn:hover {
  background: rgba(50, 58, 75, 0.6);
  transform: translateY(-1px);
}

.btn.primary {
  background: var(--accent);
  border-color: var(--accent);
  color: white;
}

.btn.primary:hover {
  background: var(--accent-light);
  border-color: var(--accent-light);
}

.msg {
  margin-top: 12px;
  font-size: 0.9rem;
  padding: 10px 12px;
  border-radius: 10px;
}

.msg.success {
  background: rgba(74, 222, 128, 0.1);
  color: var(--success);
  border: 1px solid rgba(74, 222, 128, 0.2);
}

.msg.error {
  background: rgba(248, 113, 113, 0.1);
  color: var(--error);
  border: 1px solid rgba(248, 113, 113, 0.2);
}

/* Preview do logo */
.logoWrap {
  display: flex;
  align-items: center;
  gap: 16px;
}

.logoBox {
  width: 72px;
  height: 72px;
  border: 1px dashed var(--line-light);
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: var(--surface-light);
  transition: all 0.2s ease;
}

.logoBox:hover {
  border-color: var(--accent);
}

.logoBox img {
  max-width: 100%;
  max-height: 100%;
  display: block;
  object-fit: contain;
}

.hint {
  color: var(--muted);
  font-size: 0.85rem;
  margin-top: 6px;
}

/* Progress bar para atualização */
.progress {
  height: 10px;
  border: 1px solid var(--line);
  border-radius: 999px;
  overflow: hidden;
  background: #101520;
  margin: 16px 0;
}

.progress .bar {
  height: 100%;
  width: 35%;
  background: var(--accent);
  border-radius: 999px;
  transform: translateX(-100%);
  animation: load 1.2s linear infinite;
}

@keyframes load {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(300%); }
}

.small {
  font-size: 0.9rem;
  color: var(--muted);
}

/* Efeitos de hover suaves */
a, button {
  transition: all 0.2s ease;
}

/* Animação de entrada suave */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Efeito de brilho nos cards */
.card:hover h3 {
  color: var(--accent-light);
}

/* Responsividade adicional */
@media (max-width: 600px) {
  .header {
    padding: 32px 16px 20px;
  }
  
  .grid {
    grid-template-columns: 1fr;
    gap: 16px;
  }
  
  .modal-card {
    padding: 20px 16px 16px;
  }
}

/* ===== Lista de Usuários (ADMIN) ===== */
.usersWrap {
  display: grid;
  gap: 12px;
  max-height: 60vh;
  overflow: auto;
  padding-right: 8px;
}

.userItem {
  border: 1px solid var(--line);
  border-radius: 14px;
  padding: 14px;
  background: var(--surface-light);
  transition: all 0.2s ease;
}

.userItem:hover {
  border-color: var(--accent-light);
}

.userHead {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 8px;
}

.userName {
  font-weight: 700;
  color: var(--text-light);
}

.userInfo {
  font-size: 0.9rem;
  color: var(--muted);
}

.badge {
  padding: 6px 10px;
  border: 1px solid var(--line);
  border-radius: 999px;
  font-size: 0.82rem;
  font-weight: 500;
}

.badge.ok {
  border-color: rgba(74, 222, 128, 0.4);
  color: var(--success);
  background: rgba(74, 222, 128, 0.1);
}

.badge.off {
  border-color: rgba(248, 113, 113, 0.4);
  color: var(--error);
  background: rgba(248, 113, 113, 0.1);
}

.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 12px;
}

.action {
  border: 1px solid var(--line-light);
  background: #1b2230;
  color: var(--text);
  padding: 8px 10px;
  border-radius: 10px;
  font-size: 0.9rem;
  cursor: pointer;
  transition: all 0.2s ease;
}

.action:hover {
  border-color: var(--accent);
  background: #20283a;
  transform: translateY(-1px);
}

.action.danger {
  border-color: rgba(248, 113, 113, 0.5);
  color: #ffd1d1;
  background: rgba(248, 113, 113, 0.1);
}

.action.danger:hover {
  background: rgba(248, 113, 113, 0.2);
}

/* Botão de forçar logout */
.action.logout {
  border-color: rgba(255, 171, 45, 0.5);
  color: #ffe4b8;
  background: rgba(255, 171, 45, 0.1);
}

.action.logout:hover {
  background: rgba(255, 171, 45, 0.2);
}
</style>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <a class="btn-logout" href="/logout">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
      <polyline points="16 17 21 12 16 7"></polyline>
      <line x1="21" y1="12" x2="9" y2="12"></line>
    </svg>
    Sair
  </a>

  <header class="header">
    <h1 class="logo">UNISYSTEM</h1>
    <div class="topbar">
      <span>Bem-vindo(a), {{ session.get('usuario') or '' }}.</span>
      {% set nv = (nivel or session.get('nivel') or 'FUNCIONARIO')|upper %}
      {% set lic_ok = lic and lic.ativa %}
      <span class="pill">Nível: {{ nv }}</span>
    </div>
  </header>

<main class="grid">
  {% if nv in ['FUNCIONARIO','GERENTE','ADMIN'] %}
  <a class="card" href="/atendimento">
    <div class="card-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
        <circle cx="9" cy="7" r="4"></circle>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
      </svg>
    </div>
    <h3>Atendimentos</h3>
    <p>Abrir, acompanhar e finalizar atendimentos aos clientes.</p>
  </a>
  <a class="card" href="/estoque">
    <div class="card-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <path d="M16 10a4 4 0 0 1-8 0"></path>
      </svg>
    </div>
    <h3>Estoque</h3>
    <p>Gerenciar produtos, entradas e saídas do estoque.</p>
  </a>
  {% endif %}

  {% if nv == 'ADMIN' %}
  <a class="card" href="/relatorios">
    <div class="card-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="20" x2="12" y2="10"></line>
        <line x1="18" y1="20" x2="18" y2="4"></line>
        <line x1="6" y1="20" x2="6" y2="16"></line>
      </svg>
    </div>
    <h3>Relatórios</h3>
    <p>Visualizar vendas, serviços e métricas da loja.</p>
  </a>

  <a class="card" href="#" id="abrirAtualizador">
    <div class="card-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12a9 9 0 0 1-9 9 9 9 0 0 1-9-9 9 9 0 0 1 9-9"></path>
        <path d="M17 9l-4-4-4 4"></path>
        <path d="M12 2v7"></path>
      </svg>
    </div>
    <h3>Atualizador</h3>
    <p>Aplicar pacote de atualização do sistema.</p>
  </a>

  <!-- Card para listar usuários -->
  <a class="card" href="#" id="abrirUsuarios">
    <div class="card-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
        <circle cx="9" cy="7" r="4"></circle>
        <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
      </svg>
    </div>
    <h3>Usuários cadastrados</h3>
    <p>Listar e gerenciar usuários do sistema.</p>
  </a>

  <a class="card" href="#" id="abrirNovoUsuario">
    <div class="card-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
        <circle cx="8.5" cy="7" r="4"></circle>
        <line x1="20" y1="8" x2="20" y2="14"></line>
        <line x1="23" y1="11" x2="17" y2="11"></line>
      </svg>
    </div>
    <h3>Novo usuário</h3>
    <p>Criar acesso para novos colaboradores da equipe.</p>
  </a>

  <a class="card" href="#" id="abrirConfig">
    <div class="card-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="3"></circle>
        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33H9a1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
      </svg>
    </div>
    <h3>Configurações</h3>
    <p>Personalizar nome da loja, endereço e logotipo.</p>
  </a>
  
  {% if not lic_ok %}
  <!-- Card visível enquanto a licença estiver INATIVA (qualquer nível) -->
  <a class="card" href="#" id="abrirLicenca">
    <div class="card-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 1l3 5 5 1-4 4 1 6-5-3-5 3 1-6-4-4 5-1z"></path>
      </svg>
    </div>
    <h3>Ativar licença</h3>
    <p>Envie o arquivo .lic e confirme sua senha de administrador.</p>
  </a>
  {% endif %}

  {% else %}
  <a class="card" href="#" id="abrirLicenca">
    <div class="card-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 1l3 5 5 1-4 4 1 6-5-3-5 3 1-6-4-4 5-1z"></path>
      </svg>
    </div>
    <h3>Ativar licença</h3>
    <p>Envie o arquivo .lic e confirme sua senha de administrador.</p>
  </a>
  {% endif %}
</main>

<div class="footer">© BOLSONARO — {{ agora or '' }}</div>

<!-- Modal Novo Usuário -->
<div id="modalUsuario" class="modal hidden" aria-hidden="true">
  <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="titUser">
    <h3 id="titUser">Novo usuário</h3>
    <form id="formNovoUsuario">
      <div class="f"><label>Nome completo</label><input name="nome" required /></div>
      <div class="f"><label>Login</label><input name="usuario" autocomplete="off" required /></div>
      <div class="f"><label>Senha</label><input name="senha" type="password" autocomplete="new-password" required /></div>
      <div class="f"><label>Palavra-chave de recuperação</label><input name="palavra_chave" autocomplete="off" required /></div>
      <div class="f">
        <label>Nível de acesso</label>
        <select name="nivel" required>
          <option value="FUNCIONARIO" selected>Funcionário</option>
          <option value="GERENTE">Gerente</option>
          <option value="ADMIN">Administrador</option>
        </select>
      </div>
      <div class="row">
        <button type="button" class="btn" id="fecharModalUsuario">Cancelar</button>
        <button type="submit" class="btn primary">Salvar</button>
      </div>
      <div class="msg" id="msgUsuario"></div>
    </form>
  </div>
</div>

<!-- Modal Configurações (ADMIN) -->
<div id="modalConfig" class="modal hidden" aria-hidden="true">
  <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="titCfg">
    <h3 id="titCfg">Configurações do sistema</h3>
    <form id="formConfig" enctype="multipart/form-data">
      <div class="f"><label>Nome da loja</label><input id="cfgNome" name="nome_loja" placeholder="Ex.: BOLSONARO Tech"/></div>
      <div class="f"><label>Endereço</label><textarea id="cfgEnd" name="endereco" rows="3" placeholder="Rua, número, bairro, cidade"></textarea></div>
      <div class="f">
        <label>Logo</label>
        <div class="logoWrap">
          <div class="logoBox"><img id="cfgLogoPreview" alt="Logo"/></div>
          <div>
            <input id="cfgLogoFile" type="file" accept=".png,.jpg,.jpeg,.webp"/>
            <div class="hint">Até 2MB. Formatos: PNG, JPG, WEBP.</div>
          </div>
        </div>
      </div>
      <div class="row">
        <button type="button" class="btn" id="fecharConfig">Cancelar</button>
        <button type="submit" class="btn primary">Salvar</button>
      </div>
      <div class="msg" id="msgConfig"></div>
    </form>
  </div>
</div>

<!-- Modal Atualizador (ADMIN) -->
<div id="modalUpdate" class="modal hidden" aria-hidden="true">
  <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="titUpd">
    <h3 id="titUpd">Atualizar sistema</h3>
    <form id="updateForm" enctype="multipart/form-data">
      <div class="mb-3">
        <label class="form-label">Pacote de atualização (.uniupd ou .zip)</label>
        <input type="file" name="pacote" id="updFile" accept=".uniupd,.zip" required>
      </div>

      <button type="submit" class="btn btn-primary">Aplicar</button>

      <div id="updRunning" class="hidden">
        <div class="progress"><div class="bar"></div></div>
        <div class="small">Aplicando atualização... não feche a página.</div>
      </div>

      <div class="row">
        <button type="button" class="btn" id="fecharUpdate">Cancelar</button>
        <button type="submit" class="btn primary" id="btnAplicar">Aplicar</button>
      </div>
      <div class="msg" id="msgUpdate"></div>
    </form>
  </div>
</div>

<script>
(() => {
  const modalUpd = document.getElementById('modalUpdate');
  const formUpd  = document.getElementById('updateForm');
  const inpUpd   = document.getElementById('updFile');   // <= id com F maiúsculo
  const msgUpd   = document.getElementById('msgUpdate');
  const runUpd   = document.getElementById('updRunning');
  const btnClose = document.getElementById('fecharUpdate');

  if (btnClose) btnClose.addEventListener('click', () => modalUpd.classList.add('hidden'));

  if (!formUpd || !inpUpd || !msgUpd || !runUpd) return;

  formUpd.addEventListener('submit', async (e) => {
    e.preventDefault();
    msgUpd.textContent = '';
    msgUpd.className = 'msg';
    runUpd.classList.remove('hidden');

    const file = inpUpd.files && inpUpd.files[0];
    if (!file) {
      runUpd.classList.add('hidden');
      msgUpd.textContent = 'Selecione um arquivo.';
      msgUpd.className = 'msg error';
      return;
    }

    const fd = new FormData();
    fd.append('pacote', file); // nome esperado pelo backend

    inpUpd.disabled = true;
    try {
      const r = await fetch('/api/atualizar', { method: 'POST', body: fd });
      const j = await r.json().catch(() => ({}));

      if (!r.ok || j.success === false) {
        msgUpd.textContent =
          r.status === 401 ? 'Não autenticado.' :
          r.status === 403 ? 'Sem permissão (somente ADMIN).' :
          r.status === 402 ? 'Licença inativa.' :
          j.error || (j.log && j.log.join('\n')) || 'Falha ao aplicar atualização.';
        msgUpd.className = 'msg error';
      } else {
        msgUpd.textContent = 'Atualização concluída com sucesso!\n' + (j.log ? j.log.join('\n') : '');
        msgUpd.className = 'msg success';
        setTimeout(() => location.reload(), 1000);
      }
    } catch (err) {
      msgUpd.textContent = 'Erro: ' + String(err && (err.message || err));
      msgUpd.className = 'msg error';
    } finally {
      runUpd.classList.add('hidden');
      inpUpd.disabled = false;
    }
  });
})();
</script>

<!-- Modal Usuários Cadastrados (ADMIN) -->
<div id="modalUsers" class="modal hidden" aria-hidden="true">
  <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="titUsers">
    <h3 id="titUsers">Usuários cadastrados</h3>
    <div id="usersWrap" class="usersWrap">
      <div class="small">Carregando lista de usuários...</div>
    </div>
    <div class="row">
      <button type="button" class="btn" id="fecharUsers">Fechar</button>
      {% if nv == 'ADMIN' %}
      <button type="button" class="btn danger" id="forceLogoutAll">Forçar logout de todos</button>
      {% endif %}
    </div>
    <div class="msg" id="msgUsers"></div>
  </div>
</div>

<!-- Modal Licença (ID ÚNICO) -->
<div id="modalLic" class="modal hidden" aria-hidden="true">
  <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="titLic">
    <h3 id="titLic">Ativar licença</h3>
    <form id="formLicArq" enctype="multipart/form-data">
      <div class="f">
        <label>Senha do ADMIN</label>
        <input type="password" name="senha_admin" required>
      </div>
      <div class="f">
        <label>Arquivo de Licença (.lic)</label>
        <input type="file" name="arquivo" accept=".lic" required>
        <div class="hint">Selecione o arquivo .lic fornecido</div>
      </div>
      <div class="row">
        <button type="button" class="btn" id="fecharLic">Cancelar</button>
        <button type="submit" class="btn primary">Ativar</button>
      </div>
      <div class="msg" id="msgLic"></div>
    </form>
  </div>
</div>

<script>
(() => {
  const licModal   = document.getElementById('modalLic');
  const btnOpenLic = document.getElementById('abrirLicenca');
  const btnCloseLic= document.getElementById('fecharLic');
  const formLic    = document.getElementById('formLicArq');
  const licMsg     = document.getElementById('msgLic');

  if (btnOpenLic)  btnOpenLic.addEventListener('click', e => {
    e.preventDefault(); licModal.classList.remove('hidden');
  });
  if (btnCloseLic) btnCloseLic.addEventListener('click', () => {
    licModal.classList.add('hidden');
  });
  if (licModal) licModal.addEventListener('click', e => {
    if (e.target === licModal) licModal.classList.add('hidden');
  });

  if (formLic) formLic.addEventListener('submit', async e => {
    e.preventDefault();
    licMsg.textContent = 'Enviando...'; licMsg.className = 'msg';
    try {
      const fd = new FormData(formLic);
      const r  = await fetch('/api/licenca/upload', { method:'POST', body: fd });
      const j  = await r.json().catch(() => ({}));
      if (r.ok && j.ok) {
        licMsg.textContent = 'Licença ativada!'; licMsg.className = 'msg success';
        setTimeout(() => location.reload(), 800);
      } else {
        licMsg.textContent = j.error || 'Falha ao ativar'; licMsg.className = 'msg error';
      }
    } catch (err) {
      licMsg.textContent = 'Erro: ' + (err.message || err); licMsg.className = 'msg error';
    }
  });
})();
</script>

<script>
  // -------- Novo usuário --------
  const modal = document.getElementById('modalUsuario');
  const abrir = document.getElementById('abrirNovoUsuario');
  const fechar = document.getElementById('fecharModalUsuario');
  const form = document.getElementById('formNovoUsuario');
  const msg = document.getElementById('msgUsuario');

  if (abrir) abrir.addEventListener('click', (e) => { 
    e.preventDefault(); 
    modal.classList.remove('hidden'); 
    msg.textContent = ''; 
    msg.className = 'msg'; 
  });
  
  const closeUser = () => { 
    modal.classList.add('hidden'); 
    form.reset(); 
  };
  
  if (fechar) fechar.onclick = closeUser;
  
  modal.addEventListener('click', (e) => { 
    if (e.target === modal) closeUser(); 
  });
  
  window.addEventListener('keydown', (e) => { 
    if (!modal.classList.contains('hidden') && e.key === 'Escape') closeUser(); 
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    msg.textContent = 'Salvando...'; 
    msg.className = 'msg';
    
    const data = Object.fromEntries(new FormData(form).entries());
    
    try {
      const r = await fetch('/api/usuarios', { 
        method: 'POST', 
        headers: { 'Content-Type': 'application/json' }, 
        body: JSON.stringify(data) 
      });
      
      const j = await r.json();
      
      if (!r.ok) { 
        msg.textContent = j.error || 'Erro ao salvar.'; 
        msg.className = 'msg error'; 
        return; 
      }
      
      msg.textContent = 'Usuário criado com sucesso!'; 
      msg.className = 'msg success';
      setTimeout(closeUser, 1000);
    } catch { 
      msg.textContent = 'Falha na conexão.'; 
      msg.className = 'msg error'; 
    }
  });

  // -------- Configurações (ADMIN) --------
  const modalCfg = document.getElementById('modalConfig');
  const abrirCfg = document.getElementById('abrirConfig');
  const fecharCfg = document.getElementById('fecharConfig');
  const formCfg = document.getElementById('formConfig');
  const msgCfg = document.getElementById('msgConfig');
  const inpNome = document.getElementById('cfgNome');
  const inpEnd = document.getElementById('cfgEnd');
  const inpLogo = document.getElementById('cfgLogoFile');
  const prevLogo = document.getElementById('cfgLogoPreview');

  function openCfg() {
    modalCfg.classList.remove('hidden'); 
    msgCfg.textContent = '';
    msgCfg.className = 'msg';
    
    // Carrega config atual
    fetch('/api/config')
      .then(r => r.json())
      .then(j => {
        inpNome.value = j.nome_loja || '';
        inpEnd.value = j.endereco || '';
        
        if (j.imagem_logo) {
          prevLogo.src = '/static/imagens/' + j.imagem_logo;
        } else {
          prevLogo.removeAttribute('src');
        }
      })
      .catch(() => { 
        msgCfg.textContent = 'Não foi possível carregar as configurações.'; 
        msgCfg.className = 'msg error'; 
      });
  }
  
  if (abrirCfg) abrirCfg.addEventListener('click', (e) => { 
    e.preventDefault(); 
    openCfg(); 
  });
  
  const closeCfg = () => { 
    modalCfg.classList.add('hidden'); 
    formCfg.reset(); 
    prevLogo.removeAttribute('src'); 
  };
  
  if (fecharCfg) fecharCfg.onclick = closeCfg;
  
  modalCfg.addEventListener('click', (e) => { 
    if (e.target === modalCfg) closeCfg(); 
  });

  inpLogo.addEventListener('change', () => {
    const f = inpLogo.files[0];
    if (!f) { 
      prevLogo.removeAttribute('src'); 
      return; 
    }
    
    const rd = new FileReader();
    rd.onload = e => prevLogo.src = e.target.result;
    rd.readAsDataURL(f);
  });

  formCfg.addEventListener('submit', async (e) => {
    e.preventDefault();
    msgCfg.textContent = 'Salvando...'; 
    msgCfg.className = 'msg';

    try {
      let imagem_logo = null;
      
      if (inpLogo.files.length) {
        const fd = new FormData();
        fd.append('imagem', inpLogo.files[0]);
        
        const up = await fetch('/api/upload-imagem', { 
          method: 'POST', 
          body: fd 
        });
        
        const uj = await up.json();
        
        if (!up.ok) { 
          msgCfg.textContent = uj.error || 'Falha ao enviar logo.'; 
          msgCfg.className = 'msg error'; 
          return; 
        }
        
        imagem_logo = uj.imagem;
      }

      const payload = { 
        nome_loja: inpNome.value || '', 
        endereco: inpEnd.value || '' 
      };
      
      if (imagem_logo) payload.imagem_logo = imagem_logo;

      const r = await fetch('/api/config', { 
        method: 'POST', 
        headers: { 'Content-Type': 'application/json' }, 
        body: JSON.stringify(payload) 
      });
      
      const j = await r.json();
      
      if (!r.ok) { 
        msgCfg.textContent = j.error || 'Erro ao salvar configurações.'; 
        msgCfg.className = 'msg error'; 
        return; 
      }

      msgCfg.textContent = 'Configurações salvas com sucesso!'; 
      msgCfg.className = 'msg success';
      setTimeout(closeCfg, 1000);
    } catch (err) {
      msgCfg.textContent = 'Erro: ' + String(err); 
      msgCfg.className = 'msg error';
    }
  });

  // -------- Atualizador (ADMIN) --------
  const modalUpd  = document.getElementById('modalUpdate');
  const abrirUpd  = document.getElementById('abrirAtualizador');
  const fecharUpd = document.getElementById('fecharUpdate');
  const formUpd   = document.getElementById('updateForm');
  const msgUpd    = document.getElementById('msgUpdate');
  const runUpd    = document.getElementById('updRunning');
  const inpUpd    = document.getElementById('updFile');

  function openUpd() {
    modalUpd.classList.remove('hidden');
    msgUpd.textContent = '';
    msgUpd.className = 'msg';
    runUpd.classList.add('hidden');
  } 
  function closeUpd() { modalUpd.classList.add('hidden'); formUpd.reset(); }

  if (abrirUpd)  abrirUpd.addEventListener('click', e => { e.preventDefault(); openUpd(); });
  if (fecharUpd) fecharUpd.addEventListener('click', closeUpd);
  if (modalUpd)  modalUpd.addEventListener('click', e => { if (e.target === modalUpd) closeUpd(); });

  // -------- Usuários Cadastrados (ADMIN) --------
  const abrirUsers = document.getElementById('abrirUsuarios');
  const modalUsers = document.getElementById('modalUsers');
  const fecharUsers = document.getElementById('fecharUsers');
  const usersWrap = document.getElementById('usersWrap');
  const msgUsers = document.getElementById('msgUsers');
  const forceLogoutAll = document.getElementById('forceLogoutAll');

  function closeUsers(){ 
    modalUsers.classList.add('hidden'); 
    usersWrap.innerHTML = '<div class="small">Carregando lista de usuários...</div>'; 
    msgUsers.textContent=''; 
    msgUsers.className='msg'; 
  }
  
  if (fecharUsers) fecharUsers.addEventListener('click', closeUsers);
  
  if (modalUsers) modalUsers.addEventListener('click', (e) => { 
    if (e.target === modalUsers) closeUsers(); 
  });

  if (abrirUsers) abrirUsers.addEventListener('click', async (e) => {
    e.preventDefault();
    modalUsers.classList.remove('hidden');
    await loadUsers();
  });

  // Função para forçar logout de todos os usuários
  if (forceLogoutAll) {
    forceLogoutAll.addEventListener('click', async () => {
      if (!confirm('Tem certeza que deseja forçar o logout de TODOS os usuários?')) return;
      
      msgUsers.textContent = 'Processando...';
      msgUsers.className = 'msg';
      
      try {
        const r = await fetch('/api/admin/force-logout-all', { method: 'POST' });
        const j = await r.json();
        
        if (!r.ok) throw new Error(j.error || 'Erro ao forçar logout');
        
        msgUsers.textContent = j.msg || 'Todos os usuários foram desconectados com sucesso!';
        msgUsers.className = 'msg success';
      } catch (err) {
        msgUsers.textContent = 'Erro: ' + String(err.message || err);
        msgUsers.className = 'msg error';
      }
    });
  }

  async function loadUsers() {
    usersWrap.innerHTML = '<div class="small">Carregando lista de usuários...</div>';
    msgUsers.textContent = ''; 
    msgUsers.className = 'msg';
    
    try {
      // Faz a requisição para obter a lista de usuários
      const r = await fetch('/api/admin/usuarios');
      const lista = await r.json();
      
      if (!r.ok) {
        throw new Error(lista.error || 'Falha ao listar usuários.');
      }
      
      if (!Array.isArray(lista) || !lista.length) {
        usersWrap.innerHTML = '<div class="small">Nenhum usuário encontrado.</div>';
        return;
      }
      
      // Limpa o container e adiciona cada usuário
      usersWrap.innerHTML = '';
      lista.forEach(u => usersWrap.appendChild(renderUserItem(u)));
      
    } catch(err) {
      usersWrap.innerHTML = '';
      msgUsers.textContent = 'Erro: ' + String(err.message || err);
      msgUsers.className = 'msg error';
    }
  }

  function renderUserItem(u) {
    const ativo = !(u.desabilitado || u.ativo === 0 || u.status === 'DESABILITADO');
    const wrap = document.createElement('div');
    wrap.className = 'userItem';

    // Cabeçalho com nome e status
    const head = document.createElement('div');
    head.className = 'userHead';

    const left = document.createElement('div');
    const nome = document.createElement('div');
    nome.className = 'userName';
    nome.textContent = u.nome || '(sem nome)';

    const info = document.createElement('div');
    info.className = 'userInfo';
    info.textContent = `Login: ${u.usuario || 'não informado'}`;

    left.appendChild(nome);
    left.appendChild(info);

    const right = document.createElement('div');
    const badge = document.createElement('span');
    badge.className = 'badge ' + (ativo ? 'ok' : 'off');
    badge.textContent = ativo ? 'ATIVO' : 'DESABILITADO';
    right.appendChild(badge);

    head.appendChild(left);
    head.appendChild(right);

    // Área de ações
    const actions = document.createElement('div');
    actions.className = 'actions';

    // Ação: Alterar login
    actions.appendChild(createActionButton('Alterar login', async () => {
      const novoLogin = prompt('Novo login para "' + (u.nome||'') + '":');
      if (novoLogin === null || !novoLogin.trim()) return;
      
      const senhaAdmin = prompt('Confirme sua senha de administrador:');
      if (senhaAdmin === null || !senhaAdmin) return;
      
      try {
        await adminAction(`/api/admin/usuarios/${u.id}/alterar-login`, {
          novo_login: novoLogin.trim(),
          senha_admin: senhaAdmin
        });
      } catch (e) {
        alert(e.message || 'Erro ao alterar login');
      }
    }));

    // Ação: Alterar senha
    actions.appendChild(createActionButton('Alterar senha', async () => {
      const novaSenha = prompt('Nova senha para "' + (u.nome||'') + '": (mín. 4 caracteres)');
      if (novaSenha === null || novaSenha.length < 4) return;
      
      const confirmaSenha = prompt('Confirme a nova senha:');
      if (confirmaSenha === null || confirmaSenha !== novaSenha) {
        alert('As senhas não coincidem!');
        return;
      }
      
      const senhaAdmin = prompt('Confirme sua senha de administrador:');
      if (senhaAdmin === null || !senhaAdmin) return;
      
      try {
        await adminAction(`/api/admin/usuarios/${u.id}/alterar-senha`, {
          nova_senha: novaSenha,
          senha_admin: senhaAdmin
        });
      } catch (e) {
        alert(e.message || 'Erro ao alterar senha');
      }
    }));

    // Ação: Alterar palavra-chave
    actions.appendChild(createActionButton('Alterar palavra-chave', async () => {
      const novaChave = prompt('Nova palavra-chave para "' + (u.nome||'') + '":');
      if (novaChave === null || !novaChave.trim()) return;
      
      const senhaAdmin = prompt('Confirme sua senha de administrador:');
      if (senhaAdmin === null || !senhaAdmin) return;
      
      try {
        await adminAction(`/api/admin/usuarios/${u.id}/alterar-chave`, {
          nova_palavra_chave: novaChave.trim(),
          senha_admin: senhaAdmin
        });
      } catch (e) {
        alert(e.message || 'Erro ao alterar palavra-chave');
      }
    }));

    // Ação: Habilitar/Desabilitar
    actions.appendChild(createActionButton(
      ativo ? 'Desabilitar' : 'Habilitar', 
      async () => {
        const senhaAdmin = prompt('Confirme sua senha de administrador:');
        if (senhaAdmin === null || !senhaAdmin) return;
        
        try {
          const endpoint = ativo 
            ? `/api/admin/usuarios/${u.id}/desabilitar` 
            : `/api/admin/usuarios/${u.id}/habilitar`;
          
          await adminAction(endpoint, { senha_admin: senhaAdmin });
        } catch (e) {
          alert(e.message || 'Erro ao alterar status do usuário');
        }
      }
    ));

    // Ação: Forçar logout do usuário
    actions.appendChild(createActionButton(
      'Forçar logout', 
      async () => {
        if (!confirm(`Forçar logout do usuário "${u.nome||''}"?`)) return;
        
        try {
          await adminAction(`/api/admin/usuarios/${u.id}/force-logout`, {});
        } catch (e) {
          alert(e.message || 'Erro ao forçar logout');
        }
      },
      false,
      'logout'
    ));

    // Ação: Excluir (perigosa)
    actions.appendChild(createActionButton(
      'Excluir', 
      async () => {
        if (!confirm(`Tem certeza que deseja EXCLUIR permanentemente o usuário "${u.nome||''}"? Esta ação não pode ser desfeita.`)) {
          return;
        }
        
        const senhaAdmin = prompt('Confirme sua senha de administrador:');
        if (senhaAdmin === null || !senhaAdmin) return;
        
        try {
          await adminAction(`/api/admin/usuarios/${u.id}/excluir`, { 
            senha_admin: senhaAdmin 
          });
        } catch (e) {
          alert(e.message || 'Erro ao excluir usuário');
        }
      }, 
      true // Marca como ação perigosa
    ));

    wrap.appendChild(head);
    wrap.appendChild(actions);
    return wrap;
  }

  function createActionButton(label, handler, isDanger = false, extraClass = '') {
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'action' + (isDanger ? ' danger' : '') + (extraClass ? ' ' + extraClass : '');
    btn.textContent = label;
    
    btn.addEventListener('click', async () => {
      btn.disabled = true;
      try {
        await handler();
        await loadUsers(); // Recarrega a lista após a ação
      } catch (e) {
        alert(e.message || 'Falha na operação');
      } finally {
        btn.disabled = false;
      }
    });
    
    return btn;
  }

  async function adminAction(url, data) {
    msgUsers.textContent = 'Processando...';
    msgUsers.className = 'msg';
    
    try {
      const r = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data || {})
      });
      
      const j = await r.json().catch(() => ({}));
      
      if (!r.ok) {
        throw new Error(j.error || 'Erro na solicitação');
      }
      
      msgUsers.textContent = j.msg || 'Operação realizada com sucesso!';
      msgUsers.className = 'msg success';
      setTimeout(() => { 
        msgUsers.textContent = ''; 
        msgUsers.className = 'msg'; 
      }, 2000);
      
    } catch (err) {
      msgUsers.textContent = 'Erro: ' + String(err.message || err);
      msgUsers.className = 'msg error';
      throw err; // Re-lança o erro para ser tratado pelo chamador
    }
  }

  // ----- Licença -----
  const abrirLic = document.getElementById('abrirLicenca');
  const modalLic = document.getElementById('modalLic');
  const fecharLic = document.getElementById('fecharLic');
  const formLic = document.getElementById('formLicArq');
  const msgLic = document.getElementById('msgLic');

  function openLic(){ modalLic.classList.remove('hidden'); msgLic.textContent=''; msgLic.className='msg'; }
  function closeLic(){ modalLic.classList.add('hidden'); formLic.reset(); }

  if (abrirLic) abrirLic.addEventListener('click', e => { e.preventDefault(); openLic(); });
  if (fecharLic) fecharLic.addEventListener('click', closeLic);
  if (modalLic) modalLic.addEventListener('click', e => { if (e.target===modalLic) closeLic(); });

  formLic.addEventListener('submit', async (e) => {
    e.preventDefault();
    msgLic.textContent = 'Enviando...'; msgLic.className='msg';
    const fd = new FormData(formLic);
    try {
      const r = await fetch('/api/licenca/upload', { method:'POST', body: fd });
      const j = await r.json();
      if (!r.ok || !j.ok) throw new Error(j.error || 'Falha ao ativar');
      msgLic.textContent = 'Licença ativada!'; msgLic.className='msg success';
      setTimeout(()=>location.reload(), 800);
    } catch(err){
      msgLic.textContent = 'Erro: ' + (err.message || err); msgLic.className='msg error';
    }
  });

  // API wrapper com tratamento de erro de licença
  async function api(url, opts) {
    const r = await fetch(url, opts||{});
    const j = await r.json().catch(()=>null);
    if (j && j.error === "licenca_inativa") {
      window.location.href = "/login";
      return;
    }
    return j;
  }
</script>
</body>
</html>